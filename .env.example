# docker compose up works without this file — defaults are baked into docker-compose.yml.
# Copy to .env only to override (e.g. NODE_ENV=production with real admin credentials).
NODE_ENV=development
PORT=3000
LIBRAXIS_DB_PATH=./data/libraxis.db
LIBRAXIS_ADMIN_USERNAME=admin
LIBRAXIS_ADMIN_PASSWORD=change-me
LIBRAXIS_SESSION_TTL_DAYS=7
LIBRAXIS_MCP_API_KEY=

# OAuth 2.0 (optional — defaults shown)
# LIBRAXIS_PUBLIC_URL=http://localhost:3000
# LIBRAXIS_OAUTH_CODE_TTL_SECONDS=300
# LIBRAXIS_OAUTH_ACCESS_TOKEN_TTL_MINUTES=60
# LIBRAXIS_OAUTH_REFRESH_TOKEN_TTL_DAYS=30

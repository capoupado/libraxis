{
  "name": "libraxis",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "build": "tsc -p tsconfig.json && cp src/db/migrations/*.sql dist/src/db/migrations/",
    "build:all": "npm run build && npm run web:build",
    "dev": "tsx watch src/index.ts",
    "mcp:dev": "tsx src/mcp/stdio-server.ts",
    "web:dev": "vite --config vite.config.ts",
    "web:build": "vite build --config vite.config.ts",
    "web:preview": "vite preview --config vite.config.ts",
    "start": "node dist/src/index.js",
    "mcp:start": "node dist/src/mcp/stdio-server.js",
    "lint": "eslint .",
    "db:migrate": "tsx src/db/migrations/run-migrations.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/csrf-protection": "^7.1.0",
    "@fastify/express": "^4.0.4",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^9.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.8.0",
    "cookie": "^1.1.1",
    "d3-force": "^3.0.0",
    "dompurify": "^3.3.3",
    "dotenv": "^17.4.0",
    "fastify": "^5.8.4",
    "gray-matter": "^4.0.3",
    "jsdom": "^29.0.1",
    "marked": "^17.0.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ulid": "^3.0.2",
    "zod": "^4.3.6"
  },
